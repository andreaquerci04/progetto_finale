{
    "tasks": [
        {
            "label": "g++ build",
            "command": "g++",
            "args": ["-g", "-std=c++23", "-Wall", "-Wextra", "-pedantic", "${file}", "-o", "${fileDirname}/${fileBasenameNoExtension}"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Attività generata dal debugger."
        }
    ],
    "version": "2.0.0"
}